# Shared MySQL database used by both CIMS and the Developers workspace
DATABASE_HOST=127.0.0.1
DATABASE_PORT=3306
DATABASE_NAME=riana_cims
DATABASE_USER=riana_cims
DATABASE_PASSWORD=change-me
DATABASE_POOL_SIZE=30
DATABASE_POOL_IDLE=15

# API and authentication
VITE_API_PORT=8081
VITE_API_URL=https://cims.example.com/api
JWT_SECRET=replace-with-a-long-random-secret
CIMS_LOGIN_URL=https://cims.example.com/

# Automatic backups (cron is interpreted in this timezone)
BACKUP_TIMEZONE=Africa/Nairobi
BACKUP_RETENTION_DAYS=30

# Email delivery (Brevo)
BREVO_API_KEY=replace-me
BREVO_FROM_EMAIL=info@riana.co
BREVO_FROM_NAME=RIANA CIMS

# SMS delivery (B-Textman)
B_TEXTMAN_API_KEY=replace-me
B_TEXTMAN_API_URL=https://your-b-textman-endpoint.example/functions/v1
B_TEXTMAN_SEND_PATH=send-sms
B_TEXTMAN_BALANCE_PATH=
SMS_SENDER_ID=RIANA
NOTIFICATION_PROVIDER_TIMEOUT_MS=10000
