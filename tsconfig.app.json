{
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "lib": [
      "ES2020",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "ESNext",
    "moduleDetection": "force",
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "typeRoots": ["./node_modules/@types"],
    "noEmit": true,
    "noFallthroughCasesInSwitch": false,
    "noImplicitAny": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@crms/*": [
        "./CRMS/src/*"
      ],
      "react": ["./node_modules/@types/react/index.d.ts"],
      "react/jsx-runtime": ["./node_modules/@types/react/jsx-runtime.d.ts"],
      "react-dom": ["./node_modules/@types/react-dom/index.d.ts"],
      "@radix-ui/*": ["./node_modules/@radix-ui/*"],
      "@tanstack/react-query": ["./node_modules/@tanstack/react-query"],
      "react-router-dom": ["./node_modules/react-router-dom"],
      "react-hook-form": ["./node_modules/react-hook-form"],
      "lucide-react": ["./node_modules/lucide-react"],
      "next-themes": ["./node_modules/next-themes"],
      "recharts": ["./node_modules/recharts"],
      "sonner": ["./node_modules/sonner"]
    },
    "skipLibCheck": true,
    "strict": false,
    "target": "ES2020",
    "useDefineForClassFields": true
  },
  "include": [
    "src",
    "CRMS/src"
  ]
}
